{
  "name": "hs-tracker",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": "24.17.0",
    "npm": "11.13.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "stage:baci": "tsx scripts/release/stage-baci.ts",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "start:standalone": "node .next/standalone/server.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.4-r.1",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/yauzl": "3.4.0",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "yauzl": "3.4.0"
  }
}
